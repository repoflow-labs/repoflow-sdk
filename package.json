{
  "name": "repoflow-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for integrating with the RepoFlow protocol on Stellar",
  "type": "module",
  "sideEffects": false,
  "main": "dist/repoflow-sdk.cjs",
  "module": "dist/repoflow-sdk.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/repoflow-sdk.mjs",
      "require": "./dist/repoflow-sdk.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repoflow-labs/repoflow-sdk.git"
  },
  "keywords": [
    "stellar",
    "soroban",
    "repoflow",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "author": "RepoFlow Labs",
  "homepage": "https://github.com/repoflow-labs/repoflow-sdk#readme"
}
